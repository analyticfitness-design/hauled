# HAULED — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales

# URL del sitio (sin trailing slash)
APP_URL=https://hauled.co

# Wompi — Dashboard en https://bancolombia.com.co/wompi/desarrolladores
# Test: pub_test_ / prv_test_
# Producción: pub_stagk_ / prv_stagk_
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_SECRET_KEY=prv_test_XXXXXXXXXXXXXXXXXXXXXXXX

# WhatsApp Business (formato Colombia: 57 + número sin cero)
WHATSAPP_NUMBER=573XXXXXXXXX

# API Backend Laravel (Fase 2)
API_BASE_URL=https://api.hauled.co/api
