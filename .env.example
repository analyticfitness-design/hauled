# ═══════════════════════════════════════════════
# HAULED — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# ═══════════════════════════════════════════════

# ─── Server (EasyPanel los inyecta automáticamente) ───
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ─── App ──────────────────────────────────────────────
# Dominio público sin trailing slash
APP_URL=https://hauled.shop

# ─── WhatsApp Business ────────────────────────────────
# Formato Colombia: 57 + número (sin +, sin espacios)
WHATSAPP_NUMBER=573000000000

# ─── Wompi (pasarela de pagos Bancolombia) ────────────
# Dashboard: https://comercios.wompi.co
# Test:   pub_test_*** / prv_test_***
# Prod:   pub_prod_*** / prv_prod_***
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXX
WOMPI_SECRET_KEY=prv_test_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Base de datos PostgreSQL (EasyPanel) ─────────────
# Hostname interno: PROYECTO_SERVICIO (ej: hauled_db)
DATABASE_URL=postgres://hauled:CHANGEME@hauled_db:5432/hauled
